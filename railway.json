{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["python3", "gcc", "pkg-config"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "python3 app.py",
    "restartPolicyType": "ON_FAILURE"
  }
}
